# ─── UniFi OS console / Protect NVR (required) ────────────────────────────
# Base URL of the UniFi OS console running Protect (self-signed cert OK).
UNIFI_HOST=https://your-nvr.local
# LOCAL admin account — Ubiquiti cloud SSO accounts will NOT authenticate here.
UNIFI_USER=local-admin
UNIFI_PASSWORD=change-me
# Verify the console's TLS cert (it's self-signed, so usually false).
VERIFY_SSL=false

# ─── Viewport (required: one of these) ────────────────────────────────────
# Viewport name(s) as they appear in Protect; resolved to viewer ids.
# Comma-separate to drive multiple viewports (each reverts to its own prior view).
VIEWPORT_NAME=Living Room Viewport,Bedroom Viewport
# Or pin viewer id(s) explicitly (comma-separated); added on top of VIEWPORT_NAME.
# VIEWER_ID=

# ─── Standard server / logging block ──────────────────────────────────────
# Port the service listens on (govee=8585, sprinkler=8383, trimlight=8484).
WEBHOOK_PORT=8686
# Seconds to hold the camera's view before reverting to the previous view.
ALARM_TIMEOUT=7
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Log file inside the container (mapped to ./logs/ on the host); empty disables.
LOG_FILE=/app/logs/service.log

# ─── HomeKit enable/disable switch (optional) ─────────────────────────────
# Exposes POST /switch/on, POST /switch/off, GET /switch/state so a Homebridge
# HTTP-SWITCH accessory can turn motion-driven viewport switching on/off from
# the Home app. Set a bearer token to guard those endpoints (must match the
# Authorization header in the Homebridge accessory); empty = no auth.
SWITCH_TOKEN=
# Where the enabled/disabled flag is persisted (on the mounted ./logs volume).
STATE_FILE=/app/logs/switch_state.json
